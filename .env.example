# MemoRecipe — Docker Compose production environment variables
# These variables are consumed by docker-compose.prod.yml via
# ${VAR} interpolation. Copy this file to .env and replace all
# CHANGE_ME placeholders before running `docker compose up`.
# .env is gitignored (never commit real secrets).

# --- PostgreSQL credentials ---
# Used to initialize the postgres container AND build the API
# ConnectionStrings__DefaultConnection. Must match across both.
POSTGRES_USER=memorecipe
POSTGRES_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD
POSTGRES_DB=memorecipe

# --- JWT signing key (HMAC-SHA512) ---
# Generate with: openssl rand -base64 64
# Must be at least 64 chars. Never reuse across environments.
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_SECRET_64_CHARS_MINIMUM

# --- JWT claims (Issuer and Audience) ---
# Should match your production domain in prod.
# For local Docker compose, the values below are fine.
JWT_ISSUER=MemoRecipe
JWT_AUDIENCE=MemoRecipeUsers

# --- OCR / IA Service ---
# Base URL of the deployed Azure Function (memoRecipe-ia).
# For local testing without IA, use http://host.docker.internal:7071/api/
# (host.docker.internal = the host machine from inside a container)
OCR_SCAN_BASE_URL=CHANGE_ME_AZURE_FUNCTION_BASE_URL

# --- Image tags (GHCR registry) ---
# Specifies which image versions to pull from GHCR.
# Use semantic versioning (v0.1.0, v0.2.0, etc.) in prod for reproducibility.
# 'latest' is acceptable for dev/test but NOT recommended in prod
# (rollback impossible, "ça marchait hier" syndrome).
# To rollback: change the tag here + run `docker compose pull && up -d`.
API_IMAGE_TAG=v0.1.1
WEB_IMAGE_TAG=v0.1.0
