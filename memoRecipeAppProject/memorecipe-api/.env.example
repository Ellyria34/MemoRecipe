# Local dev environment variables for docker-compose.yml
# Copy this file to .env, replace CHANGE_ME values with your own strong passwords, then run docker-compose up.
# .env is gitignored — never commit real credentials.

# PostgreSQL
POSTGRES_USER=memorecipe
POSTGRES_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD
POSTGRES_DB=memorecipe_db

# pgAdmin (web admin GUI at http://localhost:5050)
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD
