# ============================================================
# MemoRecipe API — Production environment variables
# ============================================================
# These variables MUST be set in your production environment.
# In local dev, use appsettings.Development.json (gitignored) instead.
#
# Naming convention: ASP.NET Core uses ':' as section separator
# (e.g. "JwtSettings:Secret"), but Linux env vars can't contain ':'.
# Use '__' (double underscore) instead.
# Example: "JwtSettings:Secret" → JwtSettings__Secret
# ============================================================

# --- Database (PostgreSQL) ---
# Connection string to your production PostgreSQL instance.
# Never commit real values.
ConnectionStrings__DefaultConnection=Host=CHANGE_ME;Port=5432;Database=CHANGE_ME;Username=CHANGE_ME;Password=CHANGE_ME_USE_A_STRONG_PASSWORD

# --- JWT Authentication ---
# Secret signing key for JWT tokens. MUST be at least 64 chars, randomly generated.
# Generate one with: openssl rand -base64 64
JwtSettings__Secret=CHANGE_ME_USE_A_STRONG_RANDOM_KEY_MIN_64_CHARS

# Issuer and audience for JWT validation. Should match your prod domain.
JwtSettings__Issuer=https://api.YOUR_DOMAIN.com
JwtSettings__Audience=https://YOUR_DOMAIN.com

# --- OCR / IA Service ---
# Base URL of the deployed Azure Function (memoRecipe-ia).
OcrScan__BaseUrl=https://CHANGE_ME.azurewebsites.net

# --- CORS ---
# Allowed origin(s) for the frontend.
# Multiple origins: Cors__AllowedOrigins__0=https://YOUR_DOMAIN.com
#                   Cors__AllowedOrigins__1=https://YOUR_DOMAIN.com
Cors__AllowedOrigins__0=https://YOUR_DOMAIN.com
