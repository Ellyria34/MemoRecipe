{
  "Serilog": {
    "Using": [ "Serilog.Sinks.File", "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/memorecipe-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName" ]
  },
  "JwtSettings": {
    "Secret": "CHANGE_ME_USE_APPSETTINGS_DEVELOPMENT_JSON",
    "Issuer": "MemoRecipe",
    "Audience": "MemoRecipeUsers",
    "ExpiryMinutes": 120
  },
  "ConnectionStrings": {
    "DefaultConnection": "CHANGE_ME_USE_APPSETTINGS_DEVELOPMENT_JSON"
  },
  "OcrScan": {
    "BaseUrl": "CHANGE_ME_USE_APPSETTINGS_DEVELOPMENT_JSON"
  },
  "Cors" : {
  "AllowedOrigins": ["CHANGE_ME_USE_APPSETTINGS_DEVELOPMENT_JSON"]
  },
  "Telegram": {
    "BotToken": "CHANGE_ME_USE_APPSETTINGS_DEVELOPMENT_JSON",
    "ChatId": "CHANGE_ME_USE_APPSETTINGS_DEVELOPMENT_JSON"
  },
  "Alerting": {
    "MassPurgeCritical": 10,
    "LoginFailStormCritical": 50,
    "LoginFailStormWindow": "00:05:00",
    "ServerErrorSpikeCritical" : 20,
    "ServerErrorSpikeWindow": "00:05:00",
    "BackupPath": "/backups",
    "BackupStaleAfter": "26:00:00"
  }
}
