<MudHidden Breakpoint="Breakpoint.SmAndDown">
    <MudDrawer Open="true" Variant="DrawerVariant.Persistent" Elevation="1">
        <MudNavMenu>
            <MudNavLink Href="/" Icon="@Icons.Material.Filled.Home" Match="NavLinkMatch.All">Accueil</MudNavLink>
            <MudNavLink Href="/recipes" Icon="@Icons.Material.Filled.Book" Match="NavLinkMatch.All">Mes recettes
            </MudNavLink>
            <MudMenu @ref="_addRecipeMenu" AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft">
                <ActivatorContent>
                    <MudNavLink Icon="@Icons.Material.Filled.Add"
                                OnClick="@(() => _addRecipeMenu.OpenMenuAsync(new MouseEventArgs()))">Ajouter une recette
                    </MudNavLink>
                </ActivatorContent>
                <ChildContent>
                    <MudNavLink Href="/recipes/new" Icon="@Icons.Material.Filled.Create" Match="NavLinkMatch.All">
                        Ajouter manuellement
                    </MudNavLink>
                    @if (_scanEnabled)
                    {
                        <MudNavLink Href="/recipes/scan" Icon="@Icons.Material.Filled.AdfScanner" Match="NavLinkMatch.All">
                        À partir d'une photo
                        </MudNavLink>
                    }
                    </ChildContent>
                </MudMenu>
            </MudNavMenu>
        </MudDrawer>
    </MudHidden>