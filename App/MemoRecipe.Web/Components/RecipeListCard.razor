<MudCard Class="pa-4 mb-2" Style="height: 140px; display: flex; flex-direction: column;">
    <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Style="flex: 1; overflow: hidden;">
        <MudStack Style="flex: 1; overflow: hidden;">
            <MudText Typo="Typo.body1"
                     Style="overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; line-height: 1.3;"
                     title="@Recipe.Title">
                @Recipe.Title
            </MudText>
            <MudStack Row="true" Style="margin-top: auto;">
                @if (Recipe.TotalTimeMinutes.HasValue)
                {
                    <MudText Typo="Typo.caption">@Recipe.TotalTimeMinutes min</MudText>
                }
                @if (Recipe.Difficulty.HasValue)
                {
                    <MudText Typo="Typo.caption">@GetDifficultyLabel(Recipe.Difficulty)</MudText>
                }
                @if (Recipe.Servings.HasValue)
                {
                    <MudText Typo="Typo.caption">@Recipe.Servings @(Recipe.Servings == 1 ? "portion" : "portions")</MudText>
                }
            </MudStack>
        </MudStack>
        <MudIconButton Href="@($"/recipes/{Recipe.Id}")"
                       Icon="@Icons.Material.Filled.Visibility"
                       aria-label="@($"Voir la recette {Recipe.Title}")" />
    </MudStack>
</MudCard>
