@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudSnackbarProvider />
<MudDialogProvider />

<a class="skip-link" href="#main-content">Aller au contenu principal</a>

<MudLayout>
    <NavBar />
    <SideBar />
    <BottomNavBar />
    <MudMainContent Class="main-content-with-mobile-padding">
        <div id="main-content" tabindex="-1">
            @Body
            <Footer />
        </div>
    </MudMainContent>
</MudLayout>

<style>
    .skip-link {
        position: absolute;
        left: -9999px;
        z-index: 10000;
        padding: 8px 16px;
        background-color: #2D3436;
        color: #FFFFFF;
        text-decoration: none;
        border-radius: 4px;
    }

    .skip-link:focus {
        left: 8px;
        top: 8px;
    }

    #main-content:focus {
        outline: none;
    }

    .main-content-with-mobile-padding {
        padding-bottom: 0;
    }
    @@media (max-width: 959.98px) {
        .main-content-with-mobile-padding {
            padding-bottom: 130px !important;
        }
    }
</style>
