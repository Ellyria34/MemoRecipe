@page "/Register"
@layout AuthLayout

<MudContainer MaxWidth="MaxWidth.ExtraSmall">
    <MudPaper Elevation="3" Class="pa-4 mt-8">
        <div class="d-flex justify-center">
            <MudImage Src="logo.svg" Alt="MemoRecipe" Width="150" />
        </div>
        <MudText Typo="Typo.h5" Align="Align.Center" GutterBottom="true">S'enregistrer</MudText>
        <MudText Typo="Typo.body2" Align="Align.Center" Class="mb-6">
            Vous n'avez pas encore de compte ! Créez le pour accéder à votre espace personnel
        </MudText>

        <MudForm @bind-IsValid="_isValid">
            <MudTextField
                T="string"
                Label="Email"
                Variant="Variant.Outlined"
                InputType="InputType.Email"
                Adornment="Adornment.Start"
                AdornmentIcon="@Icons.Material.Filled.Email"
                Class="mb-4"
                @bind-Value="_email"
                Required="true"
                Validation="@((string v) => ValidateEmail(v))"
            />

            <MudTextField
                T="string"
                Label="Nom d'utilisateur"
                Variant="Variant.Outlined"
                InputType="InputType.Text"
                Adornment="Adornment.Start"
                AdornmentIcon="@Icons.Material.Filled.Person"
                Class="mb-4"
                @bind-Value="_userName"
                Required="true"
                Validation="@((string v) => ValidateUserName(v))"
            />

            <MudTextField
                T="string"
                ShrinkLabel="true" 
                Label="Mot de passe"
                Variant="Variant.Outlined"
                InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                Adornment="Adornment.End"
                AdornmentIcon="@(_showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                OnAdornmentClick="() => _showPassword = !_showPassword"
                Class="mb-4"
                @bind-Value="_password"
                Immediate="true"
                Required="true"
                Validation="@((string v) => ValidatePassword(v))"
            />

            <MudTextField
                T="string"
                ShrinkLabel="true" 
                Label="Confirmer le mot de passe"
                Variant="Variant.Outlined"
                InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                Adornment="Adornment.End"
                AdornmentIcon="@(_showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                OnAdornmentClick="() => _showPassword = !_showPassword"
                Class="mb-6"
                @bind-Value="_passwordConfirmation"
                Required="true"
                Validation="@((string v) => ValidatePasswordConfirmation(v))"
            />
        </MudForm>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
        }

        <MudButton
            Variant="Variant.Filled"
            Color="Color.Primary"
            FullWidth="true"
            Class="mb-4"
            OnClick="HandleRegister"
        >
            S'inscrire
        </MudButton>

        <MudText Align="Align.Center">
            Déjà un compte ?
            <MudLink Href="/login">Se connecter</MudLink>
        </MudText>
    </MudPaper>
</MudContainer>