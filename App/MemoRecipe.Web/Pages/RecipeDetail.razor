@page "/recipes/{id:guid}"

@attribute [Authorize]

<MudContainer MaxWidth="MaxWidth.Medium">
    <MudPaper Elevation="3" Class="pa-4 mt-4">
        @if (_recipe == null)
        {
            <div aria-live="polite" class="d-flex justify-center pa-4">
                <MudProgressCircular Indeterminate="true" aria-label="Chargement de la recette" />
            </div>
        }
        else
        {
            <MudText Typo="Typo.h4" HtmlTag="h1" Align="Align.Center" GutterBottom="true" Class="pb-4">
                @_recipe.Title
            </MudText>

            <section aria-labelledby="recipe-info-heading">
                <MudText Typo="Typo.h6" HtmlTag="h2" id="recipe-info-heading" Class="mt-4 mb-2">
                    Informations
                </MudText>

                @if (!string.IsNullOrWhiteSpace(_recipe.Description))
                {
                    <MudText Typo="Typo.body1" Class="mt-2">
                        <strong>Description :</strong> @_recipe.Description
                    </MudText>
                }

                <MudText Typo="Typo.body1" Class="mt-2">
                    <strong>Portions :</strong> @_recipe.Servings
                </MudText>

                @if (_recipe.PrepTimeMinutes > 0)
                {
                    <MudText Typo="Typo.body1" Class="mt-2">
                        <strong>Temps de préparation :</strong> @_recipe.PrepTimeMinutes min
                    </MudText>
                }

                @if (_recipe.CookTimeMinutes > 0)
                {
                    <MudText Typo="Typo.body1" Class="mt-2">
                        <strong>Temps de cuisson :</strong> @_recipe.CookTimeMinutes min
                    </MudText>
                }

                @if (_recipe.Difficulty != null)
                {
                    <MudText Typo="Typo.body1" Class="mt-2">
                        <strong>Difficulté :</strong> @GetDifficultyLabel(_recipe.Difficulty)
                        <span aria-hidden="true" class="ml-2">🧑‍🍳</span>
                    </MudText>
                }

                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-2">
                    <MudText Typo="Typo.body1"><strong>Visibilité :</strong></MudText>
                    @if (_recipe.IsPublic)
                    {
                        <MudChip T="string" Color="Color.Primary" Icon="@Icons.Material.Filled.Public">Publique</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Color="Color.Default" Icon="@Icons.Material.Filled.Lock">Privée</MudChip>
                    }
                </MudStack>
            </section>

            <section aria-labelledby="recipe-ingredients-heading">
                <MudText Typo="Typo.h6" HtmlTag="h2" id="recipe-ingredients-heading" Class="mt-6 mb-2">
                    Ingrédients
                </MudText>

                @foreach (IngredientDto ingredient in _recipe.Ingredients)
                {
                    <MudCard Class="pa-3 mb-2">
                        <MudText Typo="Typo.body1">
                            @ingredient.Name
                            @if (ingredient.Quantity > 0 || !string.IsNullOrWhiteSpace(ingredient.Unit))
                            {
                                <span class="ml-2" style="color: #6C757D;">
                                    @if (ingredient.Quantity > 0)
                                    {
                                        @ingredient.Quantity.ToString("0.##")
                                        <text> </text>
                                    }
                                    @ingredient.Unit
                                </span>
                            }
                        </MudText>
                    </MudCard>
                }
            </section>

            <section aria-labelledby="recipe-steps-heading">
                <MudText Typo="Typo.h6" HtmlTag="h2" id="recipe-steps-heading" Class="mt-6 mb-2">
                    Étapes
                </MudText>

                @foreach (StepDto step in _recipe.Steps)
                {
                    <MudCard Class="pa-3 mb-2">
                        <MudText Typo="Typo.body1">
                            <strong>@step.Order.</strong> @step.Instruction
                        </MudText>
                    </MudCard>
                }
            </section>

            <MudStack Class="mt-6">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Large"
                           FullWidth="true"
                           StartIcon="@Icons.Material.Filled.Edit"
                           Href="@($"/recipes/{Id}/edit")">
                    Modifier
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Error"
                           Size="Size.Large"
                           FullWidth="true"
                           StartIcon="@Icons.Material.Filled.DeleteForever"
                           OnClick="Delete">
                    Supprimer
                </MudButton>
            </MudStack>

            <MudMessageBox @ref="_confirmDialog" Title="Supprimer la recette" CancelText="Non, annuler">
                <MessageContent>
                    Êtes-vous sûr de vouloir supprimer cette recette ? Cette action est irréversible.
                </MessageContent>
                <YesButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Error">Oui, supprimer</MudButton>
                </YesButton>
            </MudMessageBox>
        }
    </MudPaper>
</MudContainer>
