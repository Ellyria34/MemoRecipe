@page "/recipes/new"
@attribute [Authorize]
@using MemoRecipe.Web.Helpers


<MudContainer MaxWidth="MaxWidth.Medium">
    <MudPaper Elevation="3" Class="pa-8 mt-4">
        <MudText Typo="Typo.h5" Align="Align.Center" GutterBottom="true" Class="pb-4">Nouvelle recette</MudText>
        <RecipeForm Recipe="_newRecipe" OnFormChanged="RefreshUI" />

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="ma-4">@_errorMessage</MudAlert>
        }

        <RecipeStickyActionBar IsValid="@RecipeFormValidator.IsValid(_newRecipe)" IsSaving="@_isLoading"
                               CancelConfirmTitle="Annuler la création ?" CancelConfirmMessage="Les informations saisies seront perdues."
                               OnSave="() => HandleCreation(_newRecipe!)" OnCancel="HandleCancel" />

    </MudPaper>
</MudContainer>