@page "/profile"
@attribute [Authorize]

<MudContainer MaxWidth="MaxWidth.Small" Class="my-6">
    <MudPaper Elevation="3" Class="pa-4">
        <MudText Typo="Typo.h4" HtmlTag="h1" Align="Align.Center" GutterBottom="true">Mon profil</MudText>

        <MudDivider Class="my-6" />

        <section aria-labelledby="delete-account-heading">
            <MudText Typo="Typo.h6" HtmlTag="h2" id="delete-account-heading" GutterBottom="true">
                Suppression du compte
            </MudText>

            <MudText Typo="Typo.body2" Align="Align.Justify" Class="mb-4">
                La suppression de votre compte est définitive après <strong>30 jours</strong>.
                Pendant ce délai, vous pouvez annuler en vous reconnectant.
            </MudText>
            <MudText Typo="Typo.body2" Align="Align.Justify" Class="mb-4">
                Toutes vos recettes, ingrédients, étapes et favoris seront définitivement supprimés à l'issue du délai.
            </MudText>

            <MudForm>
                <MudTextField T="string" Label="Mot de passe" Variant="Variant.Outlined"
                              InputType="@(_showPassword ? InputType.Text : InputType.Password)" Adornment="Adornment.End"
                              AdornmentIcon="@(_showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                              OnAdornmentClick="() => _showPassword = !_showPassword" Class="mb-6" @bind-Value="_password"
                              Validation="@((string v) => ValidatePassword(v))" Required="true" />
                <MudButton Variant="Variant.Filled"
                        Color="Color.Error"
                        Size="Size.Large"
                        StartIcon="@Icons.Material.Filled.DeleteForever"
                        Disabled="@string.IsNullOrEmpty(_password)"
                        OnClick="OpenDeleteDialog">
                    Supprimer mon compte
                </MudButton>

            </MudForm>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity = "Severity.Error" Class="mt-4" role="alert">@_errorMessage</MudAlert>
      
            }
        </section>

        <MudMessageBox @ref = "_confirmDialog" Title="Supprimer mon compte" CancelText="Non, annuler">
            <MessageContent>
                Cette action marque votre compte pour suppression définitive dans <strong>30 jours</strong>.
                Vous pourrez encore annuler en vous reconnectant pendant ce délai.
            </MessageContent>
            <YesButton>
                <MudButton Variant = "Variant.Filled" Color = "Color.Error">Oui, supprimer</MudButton>
            </YesButton>
        </MudMessageBox>
    </MudPaper>
</MudContainer>
