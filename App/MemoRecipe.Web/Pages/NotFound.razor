@page "/not-found"
@layout MainLayout

<MudContainer MaxWidth="MaxWidth.Small" Class="my-8">
    <MudPaper Elevation="3" Class="pa-4 text-center">
        <MudText Typo="Typo.h1" Align="Align.Center" Style="font-size: 6rem; color: #6C757D; line-height: 1;">
            404
        </MudText>

        <MudText Typo="Typo.h4" HtmlTag="h1" Align="Align.Center" GutterBottom="true" Class="mt-4">
            Page introuvable
        </MudText>

        <MudText Typo="Typo.body1" Align="Align.Center" Class="mb-6">
            Désolé, la page que vous cherchez n'existe pas ou a été déplacée.
        </MudText>

        <MudStack Row="true" Justify="Justify.Center">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Large"
                       StartIcon="@Icons.Material.Filled.Home"
                       Href="/">
                Retour à l'accueil
            </MudButton>
        </MudStack>
    </MudPaper>
</MudContainer>

