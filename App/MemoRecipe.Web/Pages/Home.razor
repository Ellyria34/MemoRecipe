@page "/"

@attribute [Authorize]

<MudContainer MaxWidth="MaxWidth.ExtraSmall">
    <MudPaper Elevation="3" Class="pa-8 mt-4">
        <MudText Typo="Typo.h5" Align="Align.Center" GutterBottom="true">Bienvenue sur Memo Recipe</MudText>
        <MudText Typo="Typo.body2" Align="Align.Center" Class="mb-6">La mémoire de vos recettes préférées</MudText>
        <MudPaper Class="pa-2">
            <MudText Typo="Typo.body1" Align="Align.Center" GutterBottom="true" Class="pa-4">Votre livre contient :
                @_recipeCount recette(s)</MudText>
                @if (_isLoading || _recipes == null)
                {
                    <MudProgressCircular Indeterminate="true" />
                }
                else if (!_recipes.Any())
                {
                    <p>Vous n'avez encore aucune recette sauvegardé</p>
                }
                else
                {
                    @foreach (RecipeDto recipe in _recipes)
                    {
                        <RecipeListCard Recipe="@recipe" />
                    }
                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <MudAlert Severity="Severity.Error" Class="ma-4">@_errorMessage</MudAlert>
                    }
                }
            </MudPaper>
        </MudPaper>
    </MudContainer>
