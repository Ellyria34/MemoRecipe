@page "/"

@attribute [Authorize]

<MudContainer MaxWidth="MaxWidth.Medium">
    <MudPaper Elevation="3" Class="pa-4 mt-4">
        <MudText Typo="Typo.h4" HtmlTag="h1" Align="Align.Center" GutterBottom="true">
            Bienvenue sur Memo Recipe
        </MudText>
        <MudText Typo="Typo.body2" Align="Align.Center" Class="mb-6">
            La mémoire de vos recettes préférées
        </MudText>

        <MudText Typo="Typo.body1" Align="Align.Center" Class="mb-4">
            Votre livre contient : <strong>@_recipeCount</strong> recette(s)
        </MudText>

        <section aria-labelledby="recent-recipes-heading">
            <MudText Typo="Typo.h6" HtmlTag="h2" id="recent-recipes-heading" Class="mt-4 mb-2">
                Vos dernières recettes
            </MudText>

            @if (_isLoading || _recipes == null)
            {
                <div aria-live="polite" class="d-flex justify-center pa-4">
                    <MudProgressCircular Indeterminate="true" aria-label="Chargement des recettes" />
                </div>
            }
            else if (!_recipes.Any())
            {
                <MudText Typo="Typo.body1" Align="Align.Center" Class="pa-4">
                    Vous n'avez encore aucune recette sauvegardée.
                </MudText>
            }
            else
            {
                <MudGrid Spacing="2" Class="mt-2">
                    @foreach (RecipeDto recipe in _recipes)
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <RecipeListCard Recipe="@recipe" />
                        </MudItem>
                    }
                </MudGrid>
            }

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="ma-4" role="alert">@_errorMessage</MudAlert>
            }
        </section>
    </MudPaper>
</MudContainer>
