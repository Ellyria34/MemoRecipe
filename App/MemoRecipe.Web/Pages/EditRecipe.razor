@page "/recipes/{Id:guid}/edit"
@attribute [Authorize]

<MudContainer MaxWidth = "MaxWidth.ExtraSmall">
    <MudPaper Elevation="3" Class="pa-8 mt-4" >
        @if (_isLoading)
        {
            <MudProgressCircular Indeterminate="true" />
        }
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="ma-4">@_errorMessage</MudAlert>
        }

        @if (_recipe == null)
        {
            <MudProgressCircular Indeterminate="true" />
        }
        else
        {
            <MudText Typo="Typo.h5" Align="Align.Center" GutterBottom="true" Class="pb-4">Modifier la recette</MudText>
            <RecipeForm Recipe="_recipeForm" OnSave="HandleModification"/>
            <div  Class="mt-4 d-flex flex-column align-center">
                <MudButton 
                    Variant="Variant.Filled" 
                    Color="Color.Warning" 
                    FullWidth="true"
                    OnClick="HandleCancel">
                    Annuler            
                </MudButton>
                <MudMessageBox @ref="_confirmDialog" 
                    Title="Annuler la modification de la recette" 
                    CancelText="Non">
                    <MessageContent>
                        Êtes-vous sûr de vouloir annuler les modifications seront perdues ?
                    </MessageContent>
                    <YesButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Warning">Oui</MudButton>
                    </YesButton>
                </MudMessageBox>
            </div>
        }
    </MudPaper>
</MudContainer>