@page "/recipes/{Id:guid}/edit"
@attribute [Authorize]
@using MemoRecipe.Web.Helpers

<MudContainer MaxWidth="MaxWidth.ExtraSmall">
    <MudPaper Elevation="3" Class="pa-8 mt-4">
        @if (_isLoading)
        {
            <MudProgressCircular Indeterminate="true" />
        }
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="ma-4">@_errorMessage</MudAlert>
        }

        @if (_recipe == null)
        {
            <MudProgressCircular Indeterminate="true" />
        }
        else
        {
            <MudText Typo="Typo.h5" Align="Align.Center" GutterBottom="true" Class="pb-4">Modifier la recette</MudText>
            <RecipeForm Recipe="_recipeForm" OnFormChanged="RefreshUI" />
            <RecipeStickyActionBar IsValid="@RecipeFormValidator.IsValid(_recipeForm)" IsSaving="@_isLoading"
                                   CancelConfirmTitle="Annuler la modification ?"
                                   CancelConfirmMessage="Les modifications non sauvegardées seront perdues."
                                   OnSave="() => HandleModification(_recipeForm!)" OnCancel="HandleCancel" />
        }
    </MudPaper>
</MudContainer>