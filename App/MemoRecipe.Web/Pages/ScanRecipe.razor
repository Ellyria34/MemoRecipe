@page "/recipes/new"
@attribute [Authorize]
@inject IRecipeService RecipeService

<MudContainer MaxWidth = "MaxWidth.ExtraSmall">        
    <MudPaper Class="pa-8 ma-4" Elevation="3" Align="Center">
        <MudText Typo="Typo.h5"
            Align="Align.Center"
            GutterBottom="true"
        >
            Importer une recette
        </MudText>
    <div Class="mt-8" Align="Center">
        <MudFileUpload T="IBrowserFile" FilesChanged="@UploadFile">
            <CustomContent>
                <MudButton Variant="Variant.Filled"
                    Style="text-transform: none;"
                    OnClick="@context.OpenFilePickerAsync"
                    StartIcon="@Icons.Material.Filled.CloudUpload"
                >
                    Selectionner un fichier
                </MudButton>
            </CustomContent>
            <SelectedTemplate />
        </MudFileUpload>
        @if (_selectedFile != null)
        {
            <MudText Typo="Typo.body2" Class="mt-2">
                Fichier Sélectionné : @_selectedFile.Name
                <MudIconButton Icon="@Icons.Material.Filled.Close" 
                    Size="Size.Small" 
                    Color="Color.Primary"
                    OnClick="() => _selectedFile = null" />
            </MudText>
        }else
        {
            <MudText Typo="Typo.body2" Class="mt-2">
                exemple : photo.jpg
            </MudText>
        }
        @if (_selectedFile != null)
        {
            <MudButton
                Class="mt-8"
                Disabled="_isLoading"
                Variant="Variant.Filled" 
                Color="Color.Primary"
                @onclick="HandleGeneration"            
            >
            @if (_isLoading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Génération en cours</span>
            }
            else
            {
                <span>Prévisualiser le résultats</span>
            }
        </MudButton>
        }
        </div>
    </MudPaper>
    
    @* // Previsialisation section     *@
    @if (_extractedRecipe != null)
    {
        <MudPaper Class="pa-8 ma-4" Elevation="3">
            <MudText Typo="Typo.h5" GutterBottom="true">Recette générée</MudText>
            
            <MudTextField @bind-Value="_extractedRecipe.Title" Label="Titre" />
            <MudNumericField @bind-Value="_extractedRecipe.Servings" Label="Nombre de parts" />
            
            <MudText Typo="Typo.h6" Class="mt-4">Ingrédients</MudText>
            @for (int i = 0; i < _extractedRecipe.Ingredients.Count; i++)
            {
                var index = i;
                <MudTextField @bind-Value="_extractedRecipe.Ingredients[index]"
                              Label="@($"Ingrédient {index + 1}")" />
            }
            
            <MudText Typo="Typo.h6" Class="mt-4">Étapes</MudText>
            @for (int i = 0; i < _extractedRecipe.Steps.Count; i++)
            {
                var index = i;
                <MudTextField @bind-Value="_extractedRecipe.Steps[index]"
                              Label="@($"Étape {index + 1}")" />
            }
            
            <MudButton Class="mt-4"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       @onClick ="HandleCreation" 
            >
                Sauvegarder
            </MudButton>
        </MudPaper>
    }
</MudContainer>

@code
{  
    private ExtractedRecipeDto? _extractedRecipe;
    @* private RecipeCreateDto? _newRecipe; *@
    private string? _errorMessage;
    private IBrowserFile? _selectedFile;

    bool _isLoading = false;
    bool _isValid = false;
    
    private void UploadFile(IBrowserFile file)
    {
        _selectedFile = file;
    }

    private async Task HandleGeneration()
    {
        if (_selectedFile == null) 
        {
            return;
        }
        _isLoading = true;
        _errorMessage = null;
        
        try
        {
            var stream = _selectedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            _extractedRecipe = await RecipeService.ScanImageAsync(stream);
        }
        catch (Exception ex)
        {
            _errorMessage = "Un problème est survenu lors du scan de la recette";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
